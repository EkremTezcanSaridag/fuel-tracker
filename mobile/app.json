{
  "expo": {
    "name": "PompaMetre",
    "slug": "pompa-metre",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "pompametre",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#071426",
          "dark": {
            "backgroundColor": "#071426"
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pompametre.app"
    },
    "android": {
      "package": "com.pompametre.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071426"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
