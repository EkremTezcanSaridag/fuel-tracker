{
  "expo": {
    "name": "PompaMetre",
    "slug": "pompa-metre",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "pompametre",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#071426",
          "dark": {
            "backgroundColor": "#071426"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#19E6B1",
          "defaultChannel": "fuel-alerts"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pompametre.app"
    },
    "android": {
      "package": "com.pompametre.app",
      "versionCode": 4,
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071426"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "91a0e2a4-5ebf-484f-aaf2-112efa893c35"
      }
    },
    "owner": "ekoteko12"
  }
}
